ENV=production
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO

# SQLite para desarrollo local; PostgreSQL para producción (docker-compose lo inyecta)
DATABASE_URL=sqlite:///./acta_ia.db

AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Dominio del frontend en producción, ej: https://detto.tuempresa.com
CORS_ORIGINS=*
