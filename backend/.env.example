ENV=production
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO

# SQLite para desarrollo local; PostgreSQL para producción (docker-compose lo inyecta)
DATABASE_URL=sqlite:///./acta_ia.db

AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Dominio del frontend en producción, ej: https://detto.tuempresa.com
CORS_ORIGINS=*

# ── Zitadel SSO corporativo (opcional) ───────────────────────────────────────
# Déjalo vacío para usar login local (usuario/contraseña).
# Con estos valores, el frontend mostrará "Iniciar sesión con SSO" y no el formulario local.
#
# Qué solicitarle a infraestructura:
#   1. ZITADEL_DOMAIN    → URL base de Zitadel, ej: https://auth.tuempresa.com
#   2. ZITADEL_CLIENT_ID → ID del "App" en el proyecto Detto (tipo: Web, flujo: Code)
#   3. ZITADEL_CLIENT_SECRET → secreto del App anterior
#   4. ZITADEL_PROJECT_ID    → ID del proyecto (para auditoría, opcional)
#   5. Redirect URI permitida: https://detto.tuempresa.com/api/auth/zitadel/callback
ZITADEL_DOMAIN=
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=
ZITADEL_PROJECT_ID=
